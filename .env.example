APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Same as APP_URL unless the Vue app is on another origin (then set to the SPA URL).
FRONTEND_URL="${APP_URL}"

# Google Sign-In (OAuth). Web route: GET /auth/google/callback (Laravel).
# Trong Google Cloud Console → OAuth 2.0 Client → Authorized redirect URIs:
#   phải trùng TUYỆT ĐỐI với GOOGLE_REDIRECT_URI (https, không thừa / ở cuối).
# Ví dụ staging: https://va-qlda.staging.edu.vn/auth/google/callback
# Sau khi đổi: php artisan config:clear
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
# Set true only if new Google users may auto-register as developer.
GOOGLE_LOGIN_ALLOW_REGISTER=false

# Tài khoản quản trị khi chạy php artisan db:seed (đổi mật khẩu sau khi lên production).
ADMIN_EMAIL=admin@va-schools.vn
ADMIN_INITIAL_PASSWORD=password

# PPMS: khóa tài khoản sau N lần sai mật khẩu (phút).
# PPMS_LOCKOUT_MINUTES=15
# Bật bước OTP email sau mật khẩu (role admin, pm mặc định).
# PPMS_LOGIN_MFA=false
# PPMS_LOGIN_MFA_ROLES=admin,pm
# PPMS_LOGIN_MFA_TTL=10
# Giới hạn kích thước file upload (KB): tài liệu dự án + đính kèm công việc. Mặc định 51200 (50 MB).
# PPMS_UPLOAD_MAX_FILE_KB=51200

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Shared CMS database (users, user_info) — same MySQL server as DB_* above.
CMS_DB_DATABASE=cms_db_staging

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
